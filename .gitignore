# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Environments
.venv/
venv/
env/
.conda/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Data (keep small sample data only; large/raw data should not be committed)
*.csv.gz
*.parquet
data/raw/

# Dataset caches downloaded by tutorial notebooks (torchvision/HF datasets etc.)
# — large/raw, regenerated on execution, must not be committed.
# Convention: name download dirs `_<name>_data/` so this pattern catches them.
_*_data/

# Compiled binaries from DSA tutorial src/ (Java/C++) — build from source, don't commit
*.exe
*.o
*.obj
*.class
*.out
